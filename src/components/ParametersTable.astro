---
// Renders a parameters table matching the app's endpoint-help-page panel.
// Accepts parameter objects in either the "arguments" shape ({name, type,
// required, default, description}) or the app's "parameters" shape — both have
// the same fields that matter here.

interface Param {
  name: string;
  type?: string;
  required?: boolean;
  default?: unknown;
  description?: string;
}

const { params = [] } = Astro.props as { params: Param[] };
---

{params.length > 0 && (
  <table class="oc-params">
    <thead>
      <tr>
        <th>Name</th>
        <th>Type</th>
        <th>Required</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {params.map((p) => (
        <tr>
          <td><code>{p.name}</code></td>
          <td>{p.type ?? 'string'}</td>
          <td>{p.required ? 'Yes' : 'No'}</td>
          <td>{p.description ?? ''}</td>
        </tr>
      ))}
    </tbody>
  </table>
)}
