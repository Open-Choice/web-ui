---
// Thin top bar with logo + breadcrumb slot. Used by the registry; the
// marketing site has its own Starlight-managed header.
// Plain <img> (not astro:assets <Image>) so consumers don't need Sharp.
import logo from '../assets/logo.png';
---

<header class="oc-site-header">
  <a class="oc-site-header__brand" href="https://openchoice.app/" aria-label="Open Choice home">
    <img src={logo.src} width={28} height={28} alt="" loading="eager" />
  </a>
  <nav class="oc-site-header__nav">
    <slot />
  </nav>
</header>

<style>
  .oc-site-header {
    background: var(--oc-header-bg);
    color: var(--oc-header-fg);
    padding: 0 1.5rem;
    height: 52px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid var(--oc-hairline);
  }
  .oc-site-header__brand {
    display: flex;
    align-items: center;
    line-height: 0;
  }
  .oc-site-header__brand :global(img) {
    display: block;
    filter: invert(var(--oc-logo-invert, 0));
  }
  .oc-site-header__nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
  }
  .oc-site-header :global(a) {
    color: var(--oc-header-link);
    text-decoration: none;
    font-weight: 500;
  }
  .oc-site-header :global(a:hover) {
    text-decoration: underline;
  }
  .oc-site-header :global(.sep) {
    color: var(--oc-ink-faint);
  }
</style>
